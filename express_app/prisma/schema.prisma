generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
}

model User {
    id          Int           @id @default(autoincrement())
    username    String
    email       String        @unique
    name        String?
    mobile_no   String?
    token_key   String?
    auth_key    String?
    sharesafari ShareSafari[]
}

model ShareSafari {
    id                 Int    @id @default(autoincrement())
    share_safari_title String
    type               Int    @default(1)
    slug               String @unique
    host_user_id       Int
    host_type          Int
    User               User?  @relation(fields: [userId], references: [id])
    userId             Int?
}
