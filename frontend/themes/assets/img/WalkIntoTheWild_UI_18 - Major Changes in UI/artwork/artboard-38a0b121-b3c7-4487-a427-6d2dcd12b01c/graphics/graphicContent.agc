f the Indian subcontinent wildlife & hospitality. Between 2009 and 2021, we have been awarded for our excellence in eco-tourism, our commitment to green architecture, our experienced naturalists and our pioneering mobile safari initiative.Pugdundee Safaris is recognized as one of India's leading responsible safari companies. With seven intimate jungle lodges in Central India and many bespoke wildlife travel experiences including Tiger Safaris in India, it presents the very best of the Indian subcontinent wildlife & hospitality. Between 2009 and 2021, we have been awarded for our excellence in eco-tourism, our commitment to green architecture, our experienced naturalists and our pioneering mobile safari initiative."}},{"type":"group","name":"Group 5805","meta":{"ux":{"nameL10N":"SHAPE_GROUP","constraintWidth":true,"constraintHeight":true}},"id":"4e65d84c-8147-45b5-9bcd-ed08d4dedb79","transform":{"a":1,"b":0,"c":0,"d":1,"tx":437.666015625,"ty":-263.8251953125},"group":{"children":[{"type":"shape","name":"Rectangle 282","meta":{"ux":{"nameL10N":"SHAPE_RECTANGLE","constraintLeft":true,"constraintRight":true,"constraintTop":true,"constraintBottom":true}},"id":"a58f8914-be12-4de9-87f3-c23b921303cc","transform":{"a":1,"b":0,"c":0,"d":1,"tx":811,"ty":697.8247680664062},"style":{"fill":{"type":"solid","color":{"mode":"RGB","value":{"r":245,"g":245,"b":245}}},"stroke":{"type":"solid","color":{"mode":"RGB","value":{"r":112,"g":112,"b":112},"alpha":0.30196078431372547},"width":1,"align":"inside"}},"shape":{"type":"rect","x":0,"y":0,"width":126,"height":40,"r":[20,20,20,20]}},{"type":"text","name":"Follow","meta":{"ux":{"nameL10N":"SHAPE_GROUP","constraintWidth":true,"constraintHeight":true,"singleTextObject":true,"rangedStyles":[{"length":0,"linkId":"","fontFamily":"Roboto","fontStyle":"Bold","postscriptName":"Roboto-Bold","fontSize":16,"charSpacing":0,"underline":false,"textTransform":"none","textScript":"none","fill":{"value":4279578395},"strikethrough":false,"hyperlinkUrl":"