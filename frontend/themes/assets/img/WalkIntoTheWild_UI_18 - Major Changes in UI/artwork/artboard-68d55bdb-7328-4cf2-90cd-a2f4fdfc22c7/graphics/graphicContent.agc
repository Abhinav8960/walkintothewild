6-8da3-60d9c2fa3c2b","transform":{"a":1,"b":0,"c":0,"d":1,"tx":663.9487915039062,"ty":533},"style":{"fill":{"type":"solid","color":{"mode":"RGB","value":{"r":21,"g":28,"b":44}}},"stroke":{"type":"none","color":{"mode":"RGB","value":{"r":112,"g":112,"b":112}},"width":1},"font":{"postscriptName":"Roboto-Regular","family":"Roboto","style":"Regular","size":14}},"text":{"frame":{"type":"area","width":849,"height":136},"paragraphs":[{"lines":[[{"y":13,"from":0,"to":133,"x":0}],[{"y":30,"from":133,"to":271,"x":0}],[{"y":47,"from":271,"to":398,"x":0}],[{"y":64,"from":398,"to":534,"x":0}],[{"y":81,"from":534,"to":668,"x":0}],[{"y":98,"from":668,"to":805,"x":0}],[{"y":115,"from":805,"to":932,"x":0}],[{"y":132,"from":932,"to":968,"x":0}]]}],"rawText":"Pugdundee Safaris is recognized as one of India's leading responsible safari companies. With seven intimate jungle lodges in Central India and many bespoke wildlife travel experiences including Tiger Safaris in India, it presents the very best of the Indian subcontinent wildlife & hospitality. Between 2009 and 2021, we have been awarded for our excellence in eco-tourism, our commitment to green architecture, our experienced naturalists and our pioneering mobile safari initiative.Pugdundee Safaris is recognized as one of India's leading responsible safari companies. With seven intimate jungle lodges in Central India and many bespoke wildlife travel experiences including Tiger Safaris in India, it presents the very best of the Indian subcontinent wildlife & hospitality. Between 2009 and 2021, we have been awarded for our excellence in eco-tourism, our commitment to green architecture, our experienced naturalists and our pioneering mobile safari initiative."}},{"type":"group","name":"Group 5805","meta":{"ux":{"nameL10N":"SHAPE_GROUP","constraintWidth":true,"constraintHeight":true}},"id":"4f996501-1eb4-4f74-b6a1-ae96f12c6cd1","transform":{"a":1,"b":0,"c":0,"d":1,"tx":437.666015625,"ty":-263.8251953125},"group":{"children":[{"type":"s